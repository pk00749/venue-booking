# 仓库根 .env.example —— 列出全部可能用到的变量，便于 onboarding
# 实际填值时按角色分文件：
#   - 前端可见：VITE_*（写进 frontend/.env）
#   - Edge Function / migrations 可见：service role / RESEND_* 等（写进 supabase/.env 或 Edge Function secrets）

# === Frontend (Vite) ===
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_BASE_URL=http://localhost:5173

# === Supabase backend（不要下发到前端）===
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# === Email (Resend) ===
RESEND_API_KEY=
MAIL_FROM="Venue Booking <noreply@your-domain.com>"
