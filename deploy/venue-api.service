[Unit]
Description=Venue Booking API
After=network.target mongodb.service

[Service]
Type=notify
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/venue-booking/backend
Environment="PATH=/opt/venue-booking/backend/venv/bin"
ExecStart=/opt/venue-booking/backend/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target