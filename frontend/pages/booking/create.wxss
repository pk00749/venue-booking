/* pages/booking/create.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.venue-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.venue-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.slot-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.slot-label {
  font-size: 28rpx;
  color: #666;
}

.slot-value {
  font-size: 28rpx;
  color: #333;
}

.slot-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #4A90D9;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 30rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  width: 140rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

.total-price {
  flex: 1;
  font-size: 28rpx;
  color: #666;
}

.price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.submit-btn {
  width: 240rpx;
  height: 88rpx;
  background: #4A90D9;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.submit-btn::after {
  border: none;
}
