<!-- pages/login/login.wxml -->
<view class="container">
  <view class="logo-section">
    <image class="logo" src="/assets/logo.png" mode="aspectFit" />
    <text class="app-name">场地预订</text>
    <text class="app-desc">便捷预订运动场地</text>
  </view>

  <view class="login-section">
    <button 
      class="wechat-btn" 
      type="primary" 
      bindtap="handleWechatLogin"
      disabled="{{loading}}"
    >
      <image class="wechat-icon" src="/assets/wechat.png" mode="aspectFit" />
      <text>{{loading ? '登录中...' : '微信授权登录'}}</text>
    </button>

    <text class="agreement">
      登录即表示同意
      <text class="link" bindtap="showAgreement">《用户协议》</text>
      和
      <text class="link" bindtap="showPrivacy">《隐私政策》</text>
    </text>
  </view>
</view>
