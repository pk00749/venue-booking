<!-- pages/venue/detail.wxml -->
<view class="container" wx:if="{{venue}}">
  <!-- 场地图片 -->
  <swiper class="venue-swiper" indicator-dots autoplay>
    <swiper-item wx:for="{{venue.images}}" wx:key="index">
      <image src="{{item}}" mode="aspectFill" class="slide-image" />
    </swiper-item>
    <swiper-item wx:if="{{!venue.images.length}}">
      <image src="/assets/venue-placeholder.png" mode="aspectFill" class="slide-image" />
    </swiper-item>
  </swiper>

  <!-- 场地信息 -->
  <view class="venue-header">
    <text class="venue-name">{{venue.name}}</text>
    <view class="venue-tags">
      <text class="tag">{{venue.type}}</text>
      <text class="tag-status">{{venue.status}}</text>
    </view>
    <text class="venue-address">{{venue.address}}</text>
    <text class="venue-desc" wx:if="{{venue.description}}">{{venue.description}}</text>
    <view class="venue-time">
      <text>营业时间: {{venue.open_time.start}} - {{venue.open_time.end}}</text>
    </view>
  </view>

  <!-- 日期选择 -->
  <view class="section">
    <text class="section-title">选择日期</text>
    <picker mode="selector" range="{{dates}}" range-key="label" bindchange="onDateChange">
      <view class="date-display">
        <text>{{selectedDate}}</text>
        <text class="arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 时段列表 -->
  <view class="section">
    <text class="section-title">可选时段</text>
    <view class="slots-grid" wx:if="{{slots.length}}">
      <view 
        wx:for="{{slots}}" 
        wx:key="_id"
        class="slot-item {{item.status === 'available' ? '' : 'slot-disabled'}}"
        bindtap="goBooking"
        data-slot="{{item}}"
      >
        <text class="slot-time">{{item.start_time}}-{{item.end_time}}</text>
        <text class="slot-price">¥{{item.price}}</text>
        <text class="slot-status-text">{{item.status === 'available' ? '可订' : '已满'}}</text>
      </view>
    </view>
    <view wx:else class="empty-slots">
      <text>暂无可用时段</text>
    </view>
  </view>
</view>

<view wx:if="{{loading}}" class="loading">加载中...</view>
