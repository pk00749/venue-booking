<!-- pages/my/profile.wxml -->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-card">
    <image 
      class="avatar" 
      src="{{user.avatar || '/assets/default-avatar.png'}}" 
      mode="aspectFill"
    />
    <view class="user-info">
      <text class="nickname">{{user.nickname || '微信用户'}}</text>
      <view class="role-badges">
        <text wx:for="{{user.roles}}" wx:key="index" class="role-badge role-{{item}}">
          {{item === 'owner' ? '场主' : item === 'admin' ? '管理员' : '普通用户'}}
        </text>
      </view>
    </view>
  </view>

  <!-- 申请成为场主 -->
  <view wx:if="{{!hasOwnerRole}}" class="apply-section">
    <view class="apply-card">
      <view class="apply-info">
        <text class="apply-title">成为场主</text>
        <text class="apply-desc">管理您的场地，处理预订审核</text>
      </view>
      <button class="apply-btn" bindtap="handleApplyOwner" loading="{{applying}}">
        申请成为场主
      </button>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="menu-list">
    <view wx:if="{{hasOwnerRole}}" class="menu-item" bindtap="goOwnerVenues">
      <text class="menu-icon">🏢</text>
      <text class="menu-text">我的场地</text>
      <text class="arrow">›</text>
    </view>
    <view wx:if="{{hasOwnerRole}}" class="menu-item" bindtap="goOwnerBookings">
      <text class="menu-icon">📋</text>
      <text class="menu-text">预订审核</text>
      <text class="arrow">›</text>
    </view>
    <view wx:if="{{isAdmin}}" class="menu-item" bindtap="goAdminUsers">
      <text class="menu-icon">👥</text>
      <text class="menu-text">用户管理</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item logout" bindtap="handleLogout">
      <text class="menu-icon">🚪</text>
      <text class="menu-text logout-text">退出登录</text>
    </view>
  </view>
</view>
