<!-- pages/my/bookings.wxml -->
<view class="container">
  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:elif="{{bookings.length === 0}}" class="empty">
    <text>暂无预订记录</text>
    <button class="go-btn" bindtap="goIndex" type="primary" size="mini">去预订</button>
  </view>
  <view wx:else class="booking-list">
    <view wx:for="{{bookings}}" wx:key="_id" class="booking-card">
      <view class="booking-header">
        <text class="booking-status status-{{item.status}}">
          {{statusMap[item.status] || item.status}}
        </text>
        <text class="booking-id">#{{item._id}}</text>
      </view>
      <view class="booking-info">
        <text class="booking-venue">{{item.venue_id}}</text>
        <text class="booking-slot">{{item.slot_id}}</text>
      </view>
      <view class="booking-detail">
        <text>联系人: {{item.contact_name}}</text>
        <text>电话: {{item.contact_phone}}</text>
        <text>总价: ¥{{item.total_price}}</text>
      </view>
      <view class="booking-actions" wx:if="{{item.status === 'pending' || item.status === 'confirmed'}}">
        <button 
          class="cancel-btn" 
          size="mini"
          data-id="{{item._id}}"
          bindtap="handleCancel"
        >取消预订</button>
      </view>
    </view>
  </view>
</view>
