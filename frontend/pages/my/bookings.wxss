/* pages/my/bookings.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.loading, .empty {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.go-btn {
  background: #4A90D9;
  color: #fff;
  border: none;
}

.booking-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.booking-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.booking-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.booking-status {
  font-size: 28rpx;
  font-weight: bold;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
}

.status-pending {
  color: #faad14;
  background: rgba(250, 173, 20, 0.1);
}

.status-confirmed {
  color: #52c41a;
  background: rgba(82, 196, 26, 0.1);
}

.status-cancelled {
  color: #999;
  background: rgba(0, 0, 0, 0.08);
}

.status-completed {
  color: #4A90D9;
  background: rgba(74, 144, 217, 0.1);
}

.booking-id {
  font-size: 24rpx;
  color: #999;
}

.booking-info {
  margin-bottom: 16rpx;
}

.booking-venue {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.booking-slot {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-top: 8rpx;
}

.booking-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.booking-actions {
  display: flex;
  justify-content: flex-end;
}

.cancel-btn {
  background: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  border-radius: 32rpx;
  font-size: 26rpx;
}
