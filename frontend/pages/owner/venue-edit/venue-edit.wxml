<view class="container">
  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:else class="form">

    <!-- 场地名称 -->
    <view class="form-section">
      <view class="section-title">基本信息</view>

      <view class="form-item">
        <text class="form-label required">场地名称</text>
        <input
          class="form-input"
          placeholder="请输入场地名称"
          value="{{formData.name}}"
          bindinput="onNameInput"
          maxlength="50"
        />
      </view>

      <view class="form-item">
        <text class="form-label required">场地类型</text>
        <picker
          mode="selector"
          range="{{venueTypes}}"
          range-key="label"
          bindchange="onTypeChange"
          value="{{formData.typeIndex}}"
        >
          <view class="picker-value">
            {{venueTypes[formData.typeIndex] || '请选择场地类型'}}
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label required">场地地址</text>
        <input
          class="form-input"
          placeholder="请输入详细地址"
          value="{{formData.address}}"
          bindinput="onAddressInput"
          maxlength="100"
        />
      </view>

      <view class="form-item">
        <text class="form-label">场地描述</text>
        <textarea
          class="form-textarea"
          placeholder="介绍一下场地特色、设施等（选填）"
          value="{{formData.description}}"
          bindinput="onDescriptionInput"
          maxlength="500"
        />
      </view>
    </view>

    <!-- 场地照片 -->
    <view class="form-section">
      <view class="section-title">场地照片</view>
      <view class="image-list">
        <view
          wx:for="{{formData.images}}"
          wx:key="index"
          class="image-item"
        >
          <image
            src="{{item}}"
            mode="aspectFill"
            bindtap="previewImage"
            data-index="{{index}}"
          />
          <view
            class="image-remove"
            bindtap="removeImage"
            data-index="{{index}}"
          >×</view>
        </view>
        <view
          wx:if="{{formData.images.length < 5}}"
          class="image-add"
          bindtap="chooseImage"
        >
          <text class="add-icon">+</text>
          <text class="add-text">添加照片</text>
        </view>
      </view>
      <text class="form-hint">最多上传5张图片</text>
    </view>

    <!-- 开放时间 -->
    <view class="form-section">
      <view class="section-title">开放时间</view>

      <view class="form-item time-range">
        <text class="form-label">营业时间</text>
        <picker
          mode="time"
          value="{{formData.open_time_start}}"
          bindchange="onOpenTimeStartChange"
        >
          <view class="picker-value">{{formData.open_time_start}}</view>
        </picker>
        <text class="time-separator">至</text>
        <picker
          mode="time"
          value="{{formData.open_time_end}}"
          bindchange="onOpenTimeEndChange"
        >
          <view class="picker-value">{{formData.open_time_end}}</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">时段时长（分钟）</text>
        <picker
          mode="selector"
          range="{{slotDurations}}"
          bindchange="onSlotDurationChange"
          value="{{formData.slotDurationIndex}}"
        >
          <view class="picker-value">{{formData.slot_duration}} 分钟</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">每时段价格（元）</text>
        <input
          class="form-input"
          type="digit"
          placeholder="请输入价格"
          value="{{formData.slot_price}}"
          bindinput="onSlotPriceChange"
        />
      </view>
    </view>

    <!-- 预订设置 -->
    <view class="form-section">
      <view class="section-title">预订设置</view>

      <view class="form-item">
        <text class="form-label">需要审核</text>
        <switch
          checked="{{formData.require_approval}}"
          bindchange="onRequireApprovalChange"
        />
      </view>

      <view class="form-item">
        <text class="form-label">开场前可取消时长（小时）</text>
        <picker
          mode="selector"
          range="{{cancelHoursOptions}}"
          bindchange="onCancelHoursChange"
          value="{{formData.cancelHoursIndex}}"
        >
          <view class="picker-value">{{formData.cancel_hours}} 小时</view>
        </picker>
      </view>

      <view class="form-item" wx:if="{{isEdit}}">
        <text class="form-label">场地状态</text>
        <switch
          checked="{{formData.status === 'active'}}"
          bindchange="onStatusChange"
        />
      </view>
    </view>

    <!-- 提交按钮 -->
    <button
      class="submit-btn {{submitting ? 'disabled' : ''}}"
      bindtap="submitForm"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : (isEdit ? '保存修改' : '创建场地')}}
    </button>

  </view>
</view>
