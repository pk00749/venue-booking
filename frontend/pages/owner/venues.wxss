.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.loading, .empty {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #bbb;
}

.venue-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.venue-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.venue-img {
  width: 100%;
  height: 280rpx;
  background: #eee;
}

.venue-info {
  padding: 24rpx;
}

.venue-header {
  margin-bottom: 20rpx;
}

.venue-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.venue-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.venue-address {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-top: 8rpx;
}

.venue-meta-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 8rpx;
}

.venue-type {
  font-size: 24rpx;
  color: #4A90D9;
  background: rgba(74, 144, 217, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.venue-time {
  font-size: 24rpx;
  color: #999;
}

.status-badge {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.status-badge.active {
  color: #52c41a;
  background: rgba(82, 196, 26, 0.1);
}

.status-badge.inactive {
  color: #999;
  background: rgba(0, 0, 0, 0.08);
}

.venue-actions {
  display: flex;
  gap: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  padding: 16rpx 0;
  border-radius: 8rpx;
}

.edit-btn {
  background: #4A90D9;
  color: #fff;
}

.delete-btn {
  background: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
}

/* 浮动创建按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: #4A90D9;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
  z-index: 100;
}
