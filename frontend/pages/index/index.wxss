/* pages/index/index.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.search-bar {
  background: #fff;
  padding: 20rpx 30rpx;
}

.search-input {
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
}

.type-filter {
  background: #fff;
  white-space: nowrap;
  padding: 0 20rpx 20rpx;
}

.type-list {
  display: flex;
  gap: 16rpx;
}

.type-item {
  display: inline-block;
  padding: 10rpx 28rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
}

.type-item.active {
  background: #4A90D9;
  color: #fff;
}

.venue-list {
  flex: 1;
  padding: 20rpx;
}

.loading, .empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.venue-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.venue-img {
  width: 100%;
  height: 320rpx;
  background: #eee;
}

.venue-info {
  padding: 24rpx;
}

.venue-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.venue-type {
  font-size: 24rpx;
  color: #4A90D9;
  background: rgba(74, 144, 217, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-top: 12rpx;
}

.venue-address {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-top: 12rpx;
}
